---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeHero from '../components/home/HomeHero.astro';
import ExtensionIntro from '../components/home/ExtensionIntro.astro';
import QuickLinks from '../components/home/QuickLinks.astro';
import ImportantNotices from '../components/home/ImportantNotices.astro';
import AcademicOffer from '../components/home/AcademicOffer.astro';
import LatestNews from '../components/home/LatestNews.astro';
import AspirantsBlock from '../components/home/AspirantsBlock.astro';
import CampusLife from '../components/home/CampusLife.astro';
import UpcomingEvents from '../components/home/UpcomingEvents.astro';
import LocationContact from '../components/home/LocationContact.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import {
	academicPrograms,
	aspirantsSteps,
	campusLifeHighlights,
	contactInfo,
	heroContent,
	homeStructuredData,
	institutionalLinks,
	latestNews,
	notices,
	quickLinks,
	upcomingEvents,
} from '../data/home';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION} structuredData={homeStructuredData}>
	<HomeHero content={heroContent} />
	<ExtensionIntro />
	<QuickLinks links={quickLinks} />
	<ImportantNotices notices={notices} />
	<AcademicOffer programs={academicPrograms} />
	<LatestNews news={latestNews} />
	<AspirantsBlock steps={aspirantsSteps} />
	<CampusLife highlights={campusLifeHighlights} />
	<UpcomingEvents events={upcomingEvents} />
	<LocationContact contact={contactInfo} links={institutionalLinks} />
</BaseLayout>
