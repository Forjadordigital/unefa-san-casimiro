---
import { navigationItems, siteIdentity } from '../data/home';
---

<header class="site-header">
	<a class="skip-link" href="#contenido-principal">Saltar al contenido principal</a>
	<div class="patriot-strip" aria-hidden="true"></div>
	<nav class="site-nav" aria-label="Navegación principal">
		<a class="brand" href="/" aria-label="Ir al inicio de UNEFA Extensión San Casimiro">
			<span class="brand-mark" aria-hidden="true">U</span>
			<span class="brand-text">
				<strong>{siteIdentity.shortName}</strong>
				<small>{siteIdentity.extensionName}<br />{siteIdentity.nucleusName}</small>
			</span>
		</a>

		<div class="desktop-nav" aria-label="Secciones del Home">
			{navigationItems.map((item) => (
				<a href={item.href}>{item.label}</a>
			))}
		</div>

		<a class="header-cta" href="#contacto">Contacto</a>

		<details class="mobile-menu">
			<summary>Menú</summary>
			<div class="mobile-panel">
				{navigationItems.map((item) => (
					<a href={item.href}>{item.label}</a>
				))}
			</div>
		</details>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		background: var(--color-primary-900);
		box-shadow: var(--shadow-soft);
	}

	.patriot-strip {
		height: 4px;
		background: var(--gradient-patriot);
	}

	.skip-link {
		position: absolute;
		left: 1rem;
		top: -4rem;
		z-index: 50;
		border-radius: var(--radius-sm);
		background: var(--color-white);
		color: var(--color-primary-900);
		font-weight: 700;
		padding: 0.75rem 1rem;
		transition: top 160ms ease;
	}

	.skip-link:focus {
		top: 1rem;
	}

	.site-nav {
		display: flex;
		align-items: center;
		gap: 1rem;
		justify-content: space-between;
		width: min(var(--container-max), calc(100% - 2rem));
		margin: 0 auto;
		padding: 0.9rem 0;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		min-width: max-content;
		color: var(--color-white);
		text-decoration: none;
	}

	.brand-mark {
		display: grid;
		width: 2.75rem;
		height: 2.75rem;
		place-items: center;
		border: 2px solid var(--color-yellow-500);
		border-radius: var(--radius-full);
		background: var(--color-primary-800);
		font-weight: 800;
	}

	.brand-text {
		display: grid;
		line-height: 1.12;
	}

	.brand-text strong {
		font-size: 1rem;
		letter-spacing: 0.08em;
	}

	.brand-text small {
		color: color-mix(in srgb, var(--color-white) 82%, transparent);
		font-size: 0.76rem;
	}

	.desktop-nav {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.25rem;
		font-size: 0.86rem;
		font-weight: 700;
	}

	.desktop-nav a,
	.mobile-panel a {
		border-radius: var(--radius-full);
		color: color-mix(in srgb, var(--color-white) 86%, transparent);
		padding: 0.65rem 0.85rem;
		text-decoration: none;
		transition: background 160ms ease, color 160ms ease;
	}

	.desktop-nav a:hover,
	.desktop-nav a:focus-visible,
	.mobile-panel a:hover,
	.mobile-panel a:focus-visible {
		background: color-mix(in srgb, var(--color-white) 12%, transparent);
		color: var(--color-white);
	}

	.header-cta {
		display: inline-flex;
		align-items: center;
		min-height: 44px;
		border: 1px solid var(--color-yellow-500);
		border-radius: var(--radius-full);
		color: var(--color-yellow-500);
		font-size: 0.88rem;
		font-weight: 800;
		padding: 0.65rem 1rem;
		text-decoration: none;
	}

	.mobile-menu {
		display: none;
		position: relative;
	}

	.mobile-menu summary {
		min-height: 44px;
		border: 1px solid color-mix(in srgb, var(--color-white) 28%, transparent);
		border-radius: var(--radius-full);
		color: var(--color-white);
		cursor: pointer;
		font-weight: 800;
		list-style: none;
		padding: 0.6rem 1rem;
	}

	.mobile-menu summary::-webkit-details-marker {
		display: none;
	}

	.mobile-panel {
		position: absolute;
		right: 0;
		top: calc(100% + 0.75rem);
		display: grid;
		min-width: 16rem;
		border: 1px solid color-mix(in srgb, var(--color-white) 16%, transparent);
		border-radius: var(--radius-lg);
		background: var(--color-primary-900);
		box-shadow: var(--shadow-elevated);
		padding: 0.75rem;
	}

	@media (max-width: 1040px) {
		.desktop-nav,
		.header-cta {
			display: none;
		}

		.mobile-menu {
			display: block;
		}
	}

	@media (max-width: 420px) {
		.brand-text small {
			display: none;
		}
	}
</style>
