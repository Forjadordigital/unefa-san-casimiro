---
import { institutionalLinks, siteIdentity, contactInfo, navigationItems } from '../data/home';

const today = new Date();
---

<footer class="site-footer">
	<div class="patriot-strip" aria-hidden="true"></div>
	<div class="footer-grid">
		<section aria-labelledby="footer-brand">
			<div class="footer-brand">
				<span class="footer-mark" aria-hidden="true">U</span>
				<div>
					<h2 id="footer-brand">{siteIdentity.fullName}</h2>
					<p>{siteIdentity.extensionName} - {siteIdentity.nucleusName}</p>
				</div>
			</div>
			<p class="footer-copy">Portal informativo institucional para la comunidad universitaria de San Casimiro.</p>
		</section>

		<section aria-labelledby="footer-nav">
			<h2 id="footer-nav">Navegación</h2>
			<ul>
				{navigationItems.slice(0, 6).map((item) => (
					<li><a href={item.href}>{item.label}</a></li>
				))}
			</ul>
		</section>

		<section aria-labelledby="footer-links">
			<h2 id="footer-links">Enlaces institucionales</h2>
			<ul>
				{institutionalLinks.map((item) => (
					<li>
						<a href={item.href} target={item.href.startsWith('http') ? '_blank' : undefined} rel={item.href.startsWith('http') ? 'noreferrer' : undefined}>
							{item.label}
						</a>
					</li>
				))}
			</ul>
		</section>

		<section aria-labelledby="footer-contact">
			<h2 id="footer-contact">Contacto</h2>
			<address>{contactInfo.address}</address>
			<p class="pending-note">{contactInfo.addressStatus}</p>
		</section>
	</div>
	<div class="footer-bottom">
		<p>© {today.getFullYear()} UNEFA Extensión San Casimiro. Portal informativo institucional.</p>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--color-primary-900);
		color: color-mix(in srgb, var(--color-white) 78%, transparent);
	}

	.patriot-strip {
		height: 5px;
		background: var(--gradient-patriot);
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.6fr repeat(3, 1fr);
		gap: 2rem;
		width: min(var(--container-max), calc(100% - 2rem));
		margin: 0 auto;
		padding: var(--space-8) 0 var(--space-6);
	}

	.footer-brand {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
	}

	.footer-mark {
		display: grid;
		width: 3rem;
		height: 3rem;
		flex: 0 0 auto;
		place-items: center;
		border: 2px solid var(--color-yellow-500);
		border-radius: var(--radius-full);
		font-weight: 800;
	}

	h2 {
		margin: 0 0 1rem;
		color: var(--color-white);
		font-size: 1rem;
		letter-spacing: -0.01em;
	}

	.footer-brand h2 {
		margin-bottom: 0.35rem;
	}

	.footer-copy,
	.footer-brand p,
	address,
	.pending-note,
	.footer-bottom p {
		margin: 0;
	}

	.footer-copy {
		max-width: 32rem;
		margin-top: 1.5rem;
	}

	ul {
		display: grid;
		gap: 0.55rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	a {
		color: color-mix(in srgb, var(--color-white) 82%, transparent);
		text-decoration: none;
	}

	a:hover,
	a:focus-visible {
		color: var(--color-yellow-500);
	}

	address {
		font-style: normal;
	}

	.pending-note {
		margin-top: 0.75rem;
		color: color-mix(in srgb, var(--color-yellow-500) 82%, white);
		font-size: 0.85rem;
	}

	.footer-bottom {
		border-top: 1px solid color-mix(in srgb, var(--color-white) 12%, transparent);
		width: min(var(--container-max), calc(100% - 2rem));
		margin: 0 auto;
		padding: 1.25rem 0 2rem;
		font-size: 0.9rem;
	}

	@media (max-width: 920px) {
		.footer-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 640px) {
		.footer-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
