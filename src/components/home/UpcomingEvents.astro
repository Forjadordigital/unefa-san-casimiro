---
import type { EventItem } from '../../data/home';

interface Props {
	events: EventItem[];
}

const { events } = Astro.props;
---

<section class="events-section" aria-labelledby="events-title">
	<div class="section-shell compact events-grid">
		<div class="section-heading">
			<p class="eyebrow">Calendario</p>
			<h2 id="events-title" class="section-title">Próximas actividades</h2>
			<p class="section-copy">El calendario debe mostrar eventos vigentes. Si no hay fechas cargadas, se informa sin romper la página.</p>
		</div>
		<div>
			{events.length > 0 ? (
				<ul class="event-list">
					{events.slice(0, 3).map((event) => (
						<li>
							<time>{event.date}</time>
							<div>
								<strong>{event.title}</strong>
								<span>{event.type} · {event.location}{event.time ? ` · ${event.time}` : ''}</span>
							</div>
						</li>
					))}
				</ul>
			) : (
				<p class="empty-state">Aún no hay próximas actividades oficiales cargadas.</p>
			)}
		</div>
	</div>
</section>

<style>
	.events-section {
		background: var(--color-primary-50);
	}

	.events-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1fr);
		gap: 2rem;
		align-items: start;
	}

	.event-list {
		display: grid;
		gap: 1rem;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.event-list li {
		display: grid;
		grid-template-columns: 6rem 1fr;
		gap: 1rem;
		border: 1px solid var(--color-neutral-200);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		padding: var(--space-5);
	}

	time {
		color: var(--color-primary-800);
		font-weight: 900;
	}

	span {
		display: block;
		color: var(--color-neutral-600);
	}

	@media (max-width: 760px) {
		.events-grid,
		.event-list li {
			grid-template-columns: 1fr;
		}
	}
</style>
