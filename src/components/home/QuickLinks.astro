---
import type { QuickLink } from '../../data/home';

interface Props {
	links: QuickLink[];
}

const { links } = Astro.props;
---

<section class="quick-section" aria-labelledby="quick-title">
	<div class="section-shell compact">
		<div class="section-heading">
			<p class="eyebrow">Accesos rápidos</p>
			<h2 id="quick-title" class="section-title">Entradas directas a lo más consultado.</h2>
		</div>
		<div class="quick-grid">
			{links.map((link) => (
				<a class="quick-card" href={link.href}>
					<span class="quick-icon" aria-hidden="true">{link.icon}</span>
					<strong>{link.title}</strong>
					<span>{link.description}</span>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.quick-section {
		background: var(--color-primary-50);
	}

	.quick-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1rem;
	}

	.quick-card {
		display: grid;
		min-height: 13rem;
		align-content: start;
		gap: 0.8rem;
		border: 1px solid var(--color-neutral-200);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		color: var(--color-neutral-800);
		padding: var(--space-5);
		text-decoration: none;
		transition: border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
	}

	.quick-card:hover,
	.quick-card:focus-visible {
		border-color: var(--color-primary-800);
		box-shadow: var(--shadow-soft);
		transform: translateY(-2px);
	}

	.quick-icon {
		display: grid;
		width: 2.4rem;
		height: 2.4rem;
		place-items: center;
		border-radius: var(--radius-full);
		background: var(--color-primary-100);
		color: var(--color-primary-800);
		font-weight: 900;
	}

	strong {
		color: var(--color-neutral-950);
		font-size: 1.1rem;
	}

	span:not(.quick-icon) {
		color: var(--color-neutral-600);
		font-family: var(--font-reading);
	}

	@media (max-width: 920px) {
		.quick-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (max-width: 560px) {
		.quick-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
