---
interface Props {
	steps: string[];
}

const { steps } = Astro.props;
---

<section id="aspirantes" class="aspirants-section" aria-labelledby="aspirants-title">
	<div class="section-shell aspirants-grid">
		<div>
			<p class="eyebrow">Aspirantes</p>
			<h2 id="aspirants-title" class="section-title">¿Quieres estudiar en UNEFA San Casimiro?</h2>
			<p class="section-copy">Encuentra información sobre programas académicos, requisitos, procesos de ingreso y canales de orientación para nuevos aspirantes.</p>
			<div class="aspirants-actions">
				<a class="btn btn-primary" href="#oferta-academica">Conocer oferta académica</a>
				<a class="btn btn-secondary" href="#contacto">Contactar coordinación</a>
			</div>
		</div>
		<ol class="steps-list">
			{steps.map((step) => <li>{step}</li>)}
		</ol>
	</div>
</section>

<style>
	.aspirants-section {
		background: var(--gradient-institutional);
		color: var(--color-white);
	}

	.aspirants-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(0, 1fr);
		gap: clamp(2rem, 5vw, 4rem);
		align-items: center;
	}

	.aspirants-section :global(.eyebrow),
	.aspirants-section :global(.section-title) {
		color: var(--color-white);
	}

	.aspirants-section :global(.section-copy) {
		color: color-mix(in srgb, var(--color-white) 82%, transparent);
	}

	.aspirants-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 2rem;
	}

	.aspirants-section :global(.btn-primary) {
		background: var(--color-yellow-500);
		color: var(--color-primary-900);
	}

	.aspirants-section :global(.btn-secondary) {
		border-color: color-mix(in srgb, var(--color-white) 40%, transparent);
		background: transparent;
		color: var(--color-white);
	}

	.steps-list {
		display: grid;
		gap: 1rem;
		margin: 0;
		padding: 0;
		counter-reset: steps;
		list-style: none;
	}

	.steps-list li {
		position: relative;
		min-height: 4.5rem;
		border: 1px solid color-mix(in srgb, var(--color-white) 18%, transparent);
		border-radius: var(--radius-lg);
		background: color-mix(in srgb, var(--color-white) 8%, transparent);
		padding: 1.1rem 1.1rem 1.1rem 4.4rem;
	}

	.steps-list li::before {
		position: absolute;
		left: 1rem;
		top: 1rem;
		display: grid;
		width: 2.2rem;
		height: 2.2rem;
		place-items: center;
		border-radius: var(--radius-full);
		background: var(--color-yellow-500);
		color: var(--color-primary-900);
		content: counter(steps);
		counter-increment: steps;
		font-weight: 900;
	}

	@media (max-width: 820px) {
		.aspirants-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.aspirants-actions {
			display: grid;
		}
	}
</style>
