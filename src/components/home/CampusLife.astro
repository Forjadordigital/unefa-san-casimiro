---
interface Highlight {
	title: string;
	description: string;
}

interface Props {
	highlights: Highlight[];
}

const { highlights } = Astro.props;
---

<section class="section-shell" aria-labelledby="campus-title">
	<div class="section-heading center">
		<p class="eyebrow">Vida universitaria</p>
		<h2 id="campus-title" class="section-title">Vida universitaria en San Casimiro</h2>
		<p class="section-copy">La identidad local debe construirse con actividades, espacios y fotografías reales autorizadas. Mientras tanto, usamos un fallback institucional claro.</p>
	</div>
	<div class="campus-grid">
		{highlights.map((item) => (
			<article class="campus-card">
				<div class="campus-visual" aria-hidden="true"></div>
				<h3>{item.title}</h3>
				<p>{item.description}</p>
			</article>
		))}
	</div>
</section>

<style>
	.campus-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1rem;
	}

	.campus-card {
		border: 1px solid var(--color-neutral-200);
		border-radius: var(--radius-lg);
		background: var(--color-white);
		box-shadow: var(--shadow-soft);
		padding: var(--space-5);
	}

	.campus-visual {
		aspect-ratio: 4 / 3;
		border-radius: var(--radius-md);
		background:
			linear-gradient(135deg, rgb(7 27 73 / 86%), rgb(18 59 122 / 82%)),
			repeating-linear-gradient(45deg, rgb(255 255 255 / 8%) 0 1px, transparent 1px 18px);
		margin-bottom: 1.25rem;
	}

	h3 {
		font-size: 1.25rem;
	}

	p {
		color: var(--color-neutral-600);
		font-family: var(--font-reading);
	}

	@media (max-width: 840px) {
		.campus-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
