---
import type { heroContent } from '../../data/home';

type HeroContent = typeof heroContent;

interface Props {
	content: HeroContent;
}

const { content } = Astro.props;
---

<section class="home-hero" aria-labelledby="home-title">
	<div class="hero-inner">
		<div class="hero-copy">
			<p class="hero-kicker">Portal institucional universitario</p>
			<h1 id="home-title">{content.title}</h1>
			<p class="hero-subtitle">{content.subtitle}</p>
			<p class="hero-description">{content.description}</p>
			<div class="hero-actions">
				<a class="btn btn-primary" href={content.primaryCta.href}>{content.primaryCta.label}</a>
				<a class="btn btn-secondary" href={content.secondaryCta.href}>{content.secondaryCta.label}</a>
			</div>
		</div>

		<div class="hero-visual" role="img" aria-label="Ilustración institucional abstracta de la UNEFA San Casimiro">
			<div class="visual-card main-card">
				<span>UNEFA</span>
				<strong>San Casimiro</strong>
				<small>Núcleo Aragua</small>
			</div>
			<div class="visual-card stat-card">
				<span>Oferta de referencia</span>
				<strong>5 programas</strong>
				<small>Validación institucional pendiente</small>
			</div>
		</div>
	</div>
</section>

<style>
	.home-hero {
		background: var(--gradient-institutional);
		color: var(--color-white);
		overflow: hidden;
	}

	.hero-inner {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.72fr);
		gap: clamp(2rem, 5vw, 4rem);
		width: min(var(--container-max), calc(100% - 2rem));
		margin: 0 auto;
		padding: clamp(4rem, 8vw, 7rem) 0;
	}

	.hero-copy {
		display: grid;
		align-content: center;
		gap: 1.25rem;
	}

	.hero-kicker {
		width: fit-content;
		border-left: 4px solid var(--color-yellow-500);
		margin: 0;
		color: color-mix(in srgb, var(--color-white) 86%, transparent);
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		padding-left: 0.85rem;
		text-transform: uppercase;
	}

	h1 {
		max-width: 11ch;
		margin: 0;
		color: var(--color-white);
		font-size: clamp(3.1rem, 8vw, 6.6rem);
	}

	.hero-subtitle {
		max-width: 44rem;
		margin: 0;
		color: var(--color-yellow-500);
		font-size: clamp(1.25rem, 2vw, 1.7rem);
		font-weight: 800;
		line-height: 1.25;
	}

	.hero-description {
		max-width: 42rem;
		color: color-mix(in srgb, var(--color-white) 82%, transparent);
		font-family: var(--font-reading);
		font-size: 1.08rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 0.5rem;
	}

	.home-hero :global(.btn-primary) {
		background: var(--color-yellow-500);
		color: var(--color-primary-900);
	}

	.home-hero :global(.btn-primary:hover) {
		background: var(--color-yellow-600);
	}

	.home-hero :global(.btn-secondary) {
		border-color: color-mix(in srgb, var(--color-white) 42%, transparent);
		background: color-mix(in srgb, var(--color-white) 9%, transparent);
		color: var(--color-white);
	}

	.hero-visual {
		position: relative;
		min-height: 26rem;
		border: 1px solid color-mix(in srgb, var(--color-white) 18%, transparent);
		border-radius: var(--radius-xl);
		background:
			linear-gradient(135deg, rgb(255 255 255 / 12%), rgb(255 255 255 / 4%)),
			repeating-linear-gradient(45deg, rgb(255 255 255 / 5%) 0 1px, transparent 1px 18px);
		box-shadow: var(--shadow-elevated);
	}

	.visual-card {
		position: absolute;
		display: grid;
		border: 1px solid color-mix(in srgb, var(--color-white) 20%, transparent);
		border-radius: var(--radius-lg);
		background: color-mix(in srgb, var(--color-primary-900) 72%, transparent);
		backdrop-filter: blur(14px);
		padding: 1.4rem;
	}

	.visual-card span,
	.visual-card small {
		color: color-mix(in srgb, var(--color-white) 76%, transparent);
	}

	.visual-card strong {
		color: var(--color-white);
		font-size: 2rem;
		line-height: 1;
	}

	.main-card {
		left: 1.5rem;
		top: 1.5rem;
		right: 4rem;
		min-height: 13rem;
		justify-content: end;
	}

	.stat-card {
		right: 1.5rem;
		bottom: 1.5rem;
		max-width: 18rem;
		border-top: 4px solid var(--color-yellow-500);
	}

	@media (max-width: 860px) {
		.hero-inner {
			grid-template-columns: 1fr;
		}

		.hero-visual {
			min-height: 20rem;
		}
	}

	@media (max-width: 640px) {
		.hero-actions {
			display: grid;
		}

		.main-card {
			right: 1.5rem;
		}
	}
</style>
